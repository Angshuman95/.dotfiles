{
  "project_panel": {
    "dock": "left"
  },
  "theme": "Catppuccin Mocha",
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "auto_update": false,
  "autosave": "on_focus_change",
  "ui_font_size": 15,
  "buffer_font_family": "IosCusSemi Nerd Font",
  "buffer_font_size": 13,
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "soft_wrap": "editor_width",
  "terminal": {
    "blinking": "off",
    "shell": {
      "program": "zsh"
    }
  },
  "vim": {
    "use_system_clipboard": "never",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 300
  }
}
